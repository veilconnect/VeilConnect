# 局域网 / 无公网域名场景：Caddy 用内置 CA 自签证书（tls internal）。
# 浏览器首次访问会提示证书不受信任，点「继续/信任」即可——之后即为安全上下文(HTTPS)，
# WebCrypto / WebRTC 正常工作。适合内网、无域名、无备案的快速自部署。
{
	# 用 IP 访问时浏览器/客户端不发送 SNI，需指定默认 SNI 才能匹配到自签证书。
	default_sni {$DOMAIN}
}
# 站点地址带上 {$HTTPS_PORT}，使 Caddy 监听端口与浏览器访问端口一致（容器内外同端口映射）。
{$DOMAIN}:{$HTTPS_PORT} {
	encode zstd gzip
	tls internal
	reverse_proxy app:3001
}
