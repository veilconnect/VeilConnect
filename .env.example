# 复制为 .env 后填写。docker compose 会自动读取。

# 你的公开域名（须解析到本机公网 IP）。网页、信令、TURN realm 都用它。
DOMAIN=chat.example.com

# 本机公网 IP（coturn relay 必需；填服务器的公网 IPv4）
EXTERNAL_IP=203.0.113.10

# Caddy 监听地址。公网默认 0.0.0.0；wg/内网部署可设为内网 IP，避免在所有网卡监听。
BIND_IP=0.0.0.0

# TURN 共享密钥（coturn static-auth-secret 与 /turn-credentials 签发共用）。
# 生成一个强随机串，例如：openssl rand -hex 32
TURN_SECRET=请替换为_openssl_rand_hex_32_的输出

# --- 以下一般由 scripts/install.sh 自动写入，手动部署时按需设置 ---
# Caddy 对外端口（默认 80/443；local 自签模式避开既有服务用 8080/8443）
HTTP_PORT=80
HTTPS_PORT=443
# 挂载哪个 Caddy 配置：公网自动 HTTPS=./Caddyfile；局域网自签=./Caddyfile.local
CADDYFILE=./Caddyfile
# 浏览器实际 Origin（含非标准端口时如 https://192.168.1.10:8443），用于信令 Origin 白名单
PUBLIC_ORIGIN=https://chat.example.com
# TURN 返回给浏览器的传输：both|tcp|udp。wg/隧道环境常用 tcp，减少 UDP MTU/分片问题。
TURN_TRANSPORT=both
# coturn 抗滥用配额：封顶并发中继会话数，缓解无鉴权 /turn-credentials 被脚本盗刷中继带宽。
# 只限会话数、不限单会话 bps（避免拖慢合法 relay 文件传输）。按机器带宽调大/调小。
TURN_TOTAL_QUOTA=1200
TURN_USER_QUOTA=12
# coturn 额外参数：公网部署由 install.sh 自动填入 --no-loopback-peers + 私网段 denied-peer-ip
# （抗 SSRF，防 network_mode:host 下中继被当作打内网的跳板）。
# local/LAN 部署必须留空——否则会拒绝合法私网对端、打断局域网互连。
# TURN_EXTRA_ARGS=--no-loopback-peers --denied-peer-ip=10.0.0.0-10.255.255.255 --denied-peer-ip=192.168.0.0-192.168.255.255
# 信令详细日志：默认关闭（隐私默认，不记录 clientId/roomId/消息类型；明文 IP 不进入连接状态）。
# 仅排障时临时设 1；生产建议保持关闭，避免信令服务器沉淀"谁在何时与谁连接"的元数据。
# SIGNAL_VERBOSE=1
# 客户端 IP 只用于限流；服务端用此密钥生成不可逆 HMAC 指纹，避免在应用状态里保留明文 IP。
# 生成一个强随机串，例如：openssl rand -hex 32
SIGNAL_IP_HASH_SECRET=请替换为_openssl_rand_hex_32_的输出
# 持久化房间 token 摘要密钥；建议独立强随机。未设置时服务端会复用 SIGNAL_IP_HASH_SECRET。
# 生成一个强随机串，例如：openssl rand -hex 32
ROOM_TOKEN_HASH_SECRET=请替换为_openssl_rand_hex_32_的输出
# 持久化房间注册表路径；只保存 roomId/token 摘要/容量，不保存聊天内容。
PERSISTENT_ROOM_STORE=/data/persistent-rooms.json
# 读取 GET /metrics 的管理令牌；未设置时统计读取接口默认返回 404。
# 生成一个强随机串，例如：openssl rand -hex 32
METRICS_READ_TOKEN=请替换为_openssl_rand_hex_32_的输出
# 反向代理跳数：本栈 app 跑在 Caddy 之后，docker-compose 已默认设 TRUST_PROXY=1。
# 直接裸跑 node server/signaling-server.js（无反代）时应保持 0/不设，否则会信任客户端伪造的 X-Forwarded-For。
# 若 app 前面叠了多层代理（如 CDN→Nginx→Caddy），设为可信代理的层数。
# TRUST_PROXY=1
