{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "noEmit": true,
    "rootDir": "./src/main",
    "outDir": "./dist/electron"
  },
  "include": [
    "src/main/electron/**/*",
    "src/main/crypto/**/*",
    "src/main/identity/**/*",
    "src/main/database/**/*",
    "src/main/storage/**/*",
    "src/main/presence/**/*"
  ],
  "exclude": ["node_modules", "dist", "release"]
}
