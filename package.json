{
  "name": "veilconnect",
  "version": "2.0.5",
  "description": "VeilConnect - 可自部署的网页端到端加密聊天（P2P / WebRTC / Double Ratchet）",
  "homepage": "https://veilconnect.org",
  "license": "MIT",
  "author": {
    "name": "VeilConnect Team",
    "email": "releases@veilconnect.org"
  },
  "scripts": {
    "build:web": "webpack --config webpack.web.config.js --mode production",
    "build": "npm run build:web",
    "dev:web": "webpack serve --config webpack.web.config.js --mode development",
    "serve": "node server/signaling-server.js",
    "start": "npm run build:web && npm run serve",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "sri": "node scripts/gen-sri.js",
    "sri:check": "node scripts/gen-sri.js --check",
    "postbuild:web": "node scripts/gen-sri.js",
    "test:harness": "webpack --config infra/harness/webpack.harness.js",
    "test:browser": "webpack --config infra/harness/webpack.browser.js && node infra/harness/p2p-browser-harness.mjs",
    "test:all": "bash scripts/test-all.sh",
    "build:electron-main": "tsc -p tsconfig.electron.json --noEmit false --outDir dist/electron",
    "build:electron-renderer": "webpack --config webpack.web.config.js --mode production --env outDir=dist/renderer",
    "build:electron": "npm run build:electron-renderer && npm run build:electron-main",
    "electron:dev": "npm run build:electron && electron dist/electron/electron/main.js",
    "desktop:deps": "npm ci --prefix desktop-build",
    "dist": "npm run build:electron && ./desktop-build/node_modules/.bin/electron-builder --config electron-builder.yml"
  },
  "main": "dist/electron/electron/main.js",
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@privacyresearch/libsignal-protocol-typescript": "0.0.16",
    "electron-store": "^8.1.0",
    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "tweetnacl": "1.0.3",
    "tweetnacl-util": "0.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^6.8.0",
    "electron": "^33.4.11",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.7.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "style-loader": "^3.3.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.61.1",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "optionalDependencies": {
    "node-datachannel": "^0.32.3",
    "puppeteer": "^25.1.0"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "yaml": "^1.10.3"
  }
}
