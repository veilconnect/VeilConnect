{
  "name": "veilconnect",
  "version": "2.0.0",
  "description": "VeilConnect - 可自部署的网页端到端加密聊天（P2P / WebRTC / Double Ratchet）",
  "license": "MIT",
  "author": "VeilConnect Team",
  "scripts": {
    "build:web": "webpack --config webpack.web.config.js --mode production",
    "build": "npm run build:web",
    "dev:web": "webpack serve --config webpack.web.config.js --mode development",
    "serve": "node server/signaling-server.js",
    "start": "npm run build:web && npm run serve",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:harness": "webpack --config infra/harness/webpack.harness.js",
    "test:browser": "webpack --config infra/harness/webpack.browser.js && node infra/harness/p2p-browser-harness.mjs",
    "test:all": "bash scripts/test-all.sh"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@privacyresearch/libsignal-protocol-typescript": "^0.0.16",
    "electron-store": "^8.1.0",
    "i18next": "^23.7.0",
    "i18next-browser-languagedetector": "^7.2.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^13.5.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "css-loader": "^6.8.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.7.0",
    "process": "^0.11.10",
    "stream-browserify": "^3.0.0",
    "style-loader": "^3.3.0",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^4.15.0"
  },
  "optionalDependencies": {
    "node-datachannel": "^0.32.3",
    "puppeteer": "^25.1.0"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "ajv": "^8.20.0",
    "yaml": "^1.10.3"
  }
}
